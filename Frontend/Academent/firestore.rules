rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validNotificationType(type) {
      return type in [
        'quiz_success', 'quiz_failure',
        'flashcard_success', 'flashcard_failure',
        'pdf_upload_success', 'pdf_upload_failure',
        'exam_reminder', 'assignment_reminder', 'task_reminder', 'study_plan_reminder',
        'general_info', 'warning'
      ];
    }

    function validNotificationCreate(userId) {
      return isOwner(userId)
        && request.resource.data.userId == userId
        && validNotificationType(request.resource.data.type)
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.isRead == false
        && request.resource.data.isDeleted == false
        && (!('actionUrl' in request.resource.data) || request.resource.data.actionUrl == '' || request.resource.data.actionUrl.matches('^/[^/].*|^/$')); 
    }

    function validNotificationUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'isRead', 'readAt', 'isDeleted', 'deletedAt'
      ]);
    }

    function validSystemLogLevel(level) {
      return level in ['Information', 'Warning', 'Error', 'Critical'];
    }

    function validIssueStatus(status) {
      return status in ['New', 'Investigating', 'In progress', 'Resolved', 'Ignored', 'Reopened'];
    }

    function validAdminRole(role) {
      return role is string && role in [
        'admin', 'Admin',
        'support-admin', 'support_admin', 'support admin', 'supportAdmin', 'Support Admin',
        'content-admin', 'content_admin', 'content admin', 'contentAdmin', 'Content Admin',
        'system-admin', 'system_admin', 'system admin', 'systemAdmin', 'System Admin',
        'super-admin', 'super_admin', 'super admin', 'superAdmin', 'Super Admin'
      ];
    }

    function hasAdminEmail() {
      return request.auth.token.email is string
        && request.auth.token.email_verified == true
        && request.auth.token.email.matches('^[^@]+@academent\\.ai$');
    }

    function hasAdminClaim() {
      return ('admin' in request.auth.token && request.auth.token.admin == true)
        || ('isAdmin' in request.auth.token && request.auth.token.isAdmin == true)
        || ('role' in request.auth.token && validAdminRole(request.auth.token.role))
        || ('adminRole' in request.auth.token && validAdminRole(request.auth.token.adminRole));
    }

    function hasAdminRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          ('role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
            && validAdminRole(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role))
          || ('adminRole' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
            && validAdminRole(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.adminRole))
          || ('isAdmin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
        );
    }

    function isAdmin() {
      return isSignedIn() && (hasAdminEmail() || hasAdminClaim() || hasAdminRole());
    }

    function validSystemLogCreate() {
      return isSignedIn()
        && request.resource.data.keys().hasOnly([
          'action', 'assignedTo', 'browser', 'createdAt', 'endpoint',
          'firstOccurrence', 'latestOccurrence', 'level', 'message', 'metadata',
          'notes', 'occurrenceCount', 'relatedLogs', 'requestId', 'resolved',
          'service', 'sessionId', 'source', 'stackTrace', 'statusCode',
          'timestamp', 'updatedAt', 'url', 'user', 'userEmail', 'userId'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.user == request.auth.uid
        && request.resource.data.resolved == false
        && validSystemLogLevel(request.resource.data.level)
        && request.resource.data.action is string
        && request.resource.data.action.size() <= 120
        && request.resource.data['service'] is string
        && (request.resource.data['service']).size() > 0
        && (request.resource.data['service']).size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 900
        && request.resource.data.endpoint is string
        && request.resource.data.endpoint.size() <= 240
        && request.resource.data.requestId is string
        && request.resource.data.requestId.size() <= 80
        && request.resource.data.statusCode is int
        && request.resource.data.occurrenceCount is int
        && request.resource.data.relatedLogs is list
        && request.resource.data.metadata is map
        && request.resource.data.stackTrace is string
        && request.resource.data.stackTrace.size() <= 4000
        && request.resource.data.browser is string
        && request.resource.data.browser.size() <= 360
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() <= 180
        && request.resource.data.sessionId is string
        && request.resource.data.source == 'academent-web'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data['timestamp'] is timestamp
        && request.resource.data.firstOccurrence is timestamp
        && request.resource.data.latestOccurrence is timestamp;
    }

    function validSystemLogAdminUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'assignedTo', 'issueStatus', 'notes', 'resolved', 'updatedAt'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['resolved']) || request.resource.data.resolved is bool)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['assignedTo']) || request.resource.data.assignedTo is string)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['notes']) || request.resource.data.notes is string)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['issueStatus']) || validIssueStatus(request.resource.data.issueStatus))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();

      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if validNotificationCreate(userId);
        allow update: if isOwner(userId) && validNotificationUpdate();
        allow delete: if false;
      }

      match /settings/{settingId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /devices/{deviceId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /noteManagement/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /quizzes/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /quizAttempts/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /quizKnowledge/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /studyPlannerEvents/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /flashCardCollections/{collectionId} {
        allow read, write: if isOwner(userId);

        match /{document=**} {
          allow read, write: if isOwner(userId);
        }
      }

      match /aiTutorConversations/{conversationId} {
        allow read, write: if isOwner(userId);

        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      match /{userDocument=**} {
        allow read: if isOwner(userId) || isAdmin();
      }
    }

    match /adminAuditLogs/{auditId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /systemSettings/{settingId} {
      allow read, write: if isAdmin();
    }

    match /userReports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    match /systemLogs/{logId} {
      allow create: if validSystemLogCreate();
      allow read: if isAdmin();
      allow update: if isAdmin() && validSystemLogAdminUpdate();
      allow delete: if false;
    }

    match /scheduledNotifications/{scheduledNotificationId} {
      allow read, write: if false;
    }
  }
}
